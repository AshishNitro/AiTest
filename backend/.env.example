# ═══════════════════════════════════════════════════════════
#  PlanetAI Backend — Environment Variables
#  Copy this file to .env and fill in your actual values
#  ⚠️ NEVER commit the .env file to GitHub
# ═══════════════════════════════════════════════════════════

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/planetai

# ── OpenAI (for GPT models & embeddings) ───────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Gemini (for Gemini models & embeddings) ─────────
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Web Search (optional) ─────────────────────────────────
SERPAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BRAVE_API_KEY=BSAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Storage Paths ──────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data
UPLOAD_DIR=./uploads
